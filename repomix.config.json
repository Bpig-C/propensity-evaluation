{
  "output": {
    "filePath": "PROJECT_INDEX/history/propensity-evaluation_{datetime}.md",
    "style": "markdown",
    "showLineNumbers": false,
    "showDirectoryStructure": true,
    "copyToClipboard": false
  },
  "compression": {
    "enabled": true,
    "keepSignatures": true,
    "keepDocstrings": true,
    "keepInterfaces": true
  },
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "data/**",
      "inputs/**",
      "assets/**",
      "**/*.json",
      "**/*.md",
      "**/*.png",
      "**/*.jpg",
      "**/*.svg",
      "**/*.pyc",
      "__pycache__/**",
      "*.egg-info/**",
      "PROJECT_INDEX/**",
      "*.sh",
      "update_index.sh"
    ]
  },
  "include": []
}
